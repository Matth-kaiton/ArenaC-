<UserControl x:Class="HeroArena.Components.HeroCard"
             x:Name="component"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:HeroArena.Components"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <StackPanel>
        
        <TextBlock FontSize="20" Margin="20" TextAlignment="Center" HorizontalAlignment="Center" FontWeight="Bold"
            Text="{Binding Hero.Name, ElementName=component}"/>
        <TextBlock FontSize="20" Margin="20" TextAlignment="Center" HorizontalAlignment="Center" FontWeight="Bold"
            Text="{Binding Hero.Health, ElementName=component}"/>
        <TextBlock FontSize="20" Margin="20" TextAlignment="Center" HorizontalAlignment="Center" FontWeight="Bold"
            Text="{Binding Hero.ImageUrl, ElementName=component}"/>
        
    </StackPanel>
</UserControl>
