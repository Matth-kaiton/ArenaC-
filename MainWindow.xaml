<Window x:Class="HeroArena.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:HeroArena"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <StackPanel>
        <TextBlock FontSize="20" Margin="20" TextAlignment="Center" HorizontalAlignment="Center" FontWeight="Bold"
               Text="{Binding FisrtHero.Name}"/>
        <TextBlock FontSize="20" Margin="20" TextAlignment="Center" HorizontalAlignment="Center" FontWeight="Bold"
       Text="{Binding FisrtHero.Health}"/>
        <TextBlock FontSize="20" Margin="20" TextAlignment="Center" HorizontalAlignment="Center" FontWeight="Bold"
       Text="{Binding FisrtHero.ImageUrl}"/>
        
    </StackPanel>
</Window>
