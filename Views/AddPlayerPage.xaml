<local:BasePage x:Class="HeroArena.Views.AddPlayerPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:HeroArena.Views"
      mc:Ignorable="d" 
      Title="AddPlayerPage">

    <Grid>
        <Grid.Background>
            <ImageBrush ImageSource="/images/MainMenuBackground.jpeg" Stretch="UniformToFill"/>
        </Grid.Background>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        
        <StackPanel VerticalAlignment="Center" Grid.Column="1">
            
            <TextBlock Text="Choisissez votre pseudo de joueur"
                       Style="{StaticResource TextBlockStyle}"/>
            <TextBox x:Name="TxtPlayerName" 
                     Margin="10, 20"
                     FontSize="20"
                     Text="{Binding UsernameToAdd, UpdateSourceTrigger=PropertyChanged}"/>
            <Button Content="Valider" 
                    Style="{StaticResource ButtonStyle}"
                    Command="{Binding CreateProfilCommand}"/>

        </StackPanel>
    </Grid>
</local:BasePage>
