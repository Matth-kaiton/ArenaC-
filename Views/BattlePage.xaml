<local:BasePage x:Class="HeroArena.Views.BattlePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:local="clr-namespace:HeroArena.Views"
      Title="Combat">

    <Grid>

        <Grid.Background>
            <ImageBrush ImageSource="pack://application:,,,/images/MainMenuBackground.jpeg" Stretch="UniformToFill"/>
        </Grid.Background>
        
        <StackPanel>
            <TextBlock Text="{Binding Score, StringFormat='Ennemis vaincus : {0}'}"
                       Style="{StaticResource TextBlockStyle}"
                       Margin="10"/>

            <TextBlock Text="{Binding EnemyHero.Name}"
                       Style="{StaticResource TextBlockStyle}"/>
            <Ellipse Width="100" Height="100"  StrokeThickness="2">
                <Ellipse.Fill>
                    <ImageBrush ImageSource="{Binding EnemyHero.ImageUrl}" Stretch="UniformToFill"/>
                </Ellipse.Fill>
            </Ellipse>
            <ProgressBar Value="{Binding CurrentEnemyHealth}" 
                         Maximum="{Binding EnemyHero.Health}" 
                         Height="30" Foreground="Red" Margin="200,5,200,5"/>
            <TextBlock Text="{Binding CurrentEnemyHealth , StringFormat='{}{0} HP'}"
                       Style="{StaticResource TextBlockStyle}"
                       FontSize="10"/>

            <TextBlock Text="{Binding PlayerHero.Name}" 
                       Style="{StaticResource TextBlockStyle}"
                       />
            <Ellipse Width="100" Height="100" StrokeThickness="2">
                <Ellipse.Fill>
                    <ImageBrush ImageSource="{Binding PlayerHero.ImageUrl}" Stretch="UniformToFill"/>
                </Ellipse.Fill>
            </Ellipse>
            <ProgressBar Value="{Binding CurrentPlayerHealth}" 
                         Maximum="{Binding PlayerHero.Health}" 
                         Height="30" Foreground="Green" Margin="200,5,200,5"/>
            <TextBlock Text="{Binding CurrentPlayerHealth, StringFormat='{}{0} HP'}"
                       Style="{StaticResource TextBlockStyle}"
                       FontSize="10"/>

            <ItemsControl ItemsSource="{Binding PlayerHero.Spells}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <UniformGrid Columns="2" Margin="200,0,200,0"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Button Content="{Binding Name}"
                                Style="{StaticResource ButtonStyle}"
                                Command="{Binding DataContext.AttackCommand, RelativeSource={RelativeSource AncestorType={x:Type Page}}}"
                                CommandParameter="{Binding}"
                                Margin="5"
                                FontSize="15"/>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <Button Content="COMBAT SUIVANT" 
                    Command="{Binding RestartCommand}"
                    Style="{StaticResource ButtonStyle}"
                    Visibility="{Binding CanRestart, Converter={StaticResource BoolToVis}}"
                    Background="Gold" FontWeight="ExtraBold" Margin="200,10,200,0"/>
        </StackPanel>
    </Grid>
</local:BasePage>