<local:BasePage x:Class="HeroArena.Views.GameOverPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:HeroArena.Views"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="GameOverPage">

    <Grid>

        <Grid.Background>
            <ImageBrush ImageSource="pack://application:,,,/images/MainMenuBackground.jpeg" Stretch="UniformToFill"/>
        </Grid.Background>
        
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
            <TextBlock Text="Game Over"
                       Style="{StaticResource TextBlockStyle}"/>
            <Button Content="Return to Main Menu"
                    Style="{StaticResource ButtonStyle}"
                    Command="{Binding NavigateMainMenu}"/>
        </StackPanel>
    </Grid>
</local:BasePage>
