<local:BasePage x:Class="HeroArena.Views.HeroSelectionPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:HeroArena.Views"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="HeroSelectionPage">

    <Grid>
        <Grid.Background>
            <ImageBrush ImageSource="pack://application:,,,/images/MainMenuBackground.jpeg" Stretch="UniformToFill"/>
        </Grid.Background>

        <Border Background="#CC000000" Margin="20" CornerRadius="15">
            <Grid Margin="20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="300"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="CHOISISSEZ VOTRE HÉROS" FontSize="20" FontWeight="Bold" Foreground="Gold" HorizontalAlignment="Center" Margin="0,0,0,20"/>

                    <ListBox ItemsSource="{Binding AllHeroes}" 
                             SelectedItem="{Binding SelectedHero}"
                             Background="Transparent" BorderBrush="Gold" BorderThickness="1"
                             Height="300">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="10" BorderBrush="#33FFFFFF" BorderThickness="0,0,0,1">
                                    <TextBlock Text="{Binding Name}" FontSize="18" Foreground="White" FontWeight="SemiBold"/>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <Ellipse Width="100" Height="100" StrokeThickness="2">
                        <Ellipse.Fill>
                            <ImageBrush ImageSource="{Binding SelectedHero.ImageUrl}" Stretch="UniformToFill"/>
                        </Ellipse.Fill>
                    </Ellipse>

                    <Button Content="RETOUR"
                            Command="{Binding NagivateMainMenu}"
                            Style="{StaticResource ButtonStyle}"
                            FontSize="15"
                            Margin="10" Width="100"/>
                </StackPanel>

                <Grid Grid.Column="1" Margin="30,0,0,0">
                    <TextBlock Text="Sélectionnez un champion pour voir ses caractéristiques" 
                               Foreground="Gray" FontStyle="Italic" HorizontalAlignment="Center" VerticalAlignment="Center"/>

                    <StackPanel >
                        <TextBlock Text="{Binding SelectedHero.Name}" FontSize="48" FontWeight="Bold" Foreground="Gold"/>

                        <StackPanel Orientation="Horizontal" Margin="0,10">
                            <TextBlock Text="POINTS DE VIE : " FontSize="20" Foreground="White"/>
                            <TextBlock Text="{Binding SelectedHero.Health}" FontSize="20" Foreground="LimeGreen" FontWeight="Bold"/>
                        </StackPanel>

                        <Separator Background="Gold" Margin="0,10"/>

                        <TextBlock Text="SORTS DE DÉPART :" FontSize="18" Foreground="Gold" Margin="0,10"/>
                        <ItemsControl ItemsSource="{Binding SelectedHero.Spells}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#22FFFFFF" Margin="0,5" Padding="10" CornerRadius="5">
                                        <StackPanel>
                                            <TextBlock Text="{Binding Name}" FontWeight="Bold" Foreground="SkyBlue" FontSize="16"/>
                                            <TextBlock Text="{Binding Description}" Foreground="White" TextWrapping="Wrap" FontSize="12" FontStyle="Italic"/>
                                            <TextBlock Text="{Binding Damage, StringFormat='Dégâts : {0}'}" Foreground="OrangeRed" FontWeight="Bold" Margin="0,5,0,0"/>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <Button Content="COMMENCER LE COMBAT" 
                                Command="{Binding StartBattleCommand}"
                                Style="{StaticResource ButtonStyle}"
                                Height="50" Width="250" FontSize="15" FontWeight="Bold"
                                Margin="10">
                            <Button.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="5"/>
                                </Style>
                            </Button.Resources>
                        </Button>
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</local:BasePage>
