<Page x:Class="HeroArena.Views.MainMenuPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:HeroArena.Views"
      mc:Ignorable="d" 
      Title="MainMenuPage">

    <Grid>
        <Grid.Background>
            <ImageBrush ImageSource="pack://application:,,,/images/MainMenuBackground.jpeg" Stretch="UniformToFill"/>
        </Grid.Background>

        <StackPanel VerticalAlignment="Center">
            
            <TextBlock Text="{Binding WelcomeText}" Style="{StaticResource TextBlockStyle}"/>

            <Button Content="Jouer" Style="{StaticResource ButtonStyle}"
                    FontSize="24" FontWeight="Bold"
                    Width="200" Height="50" Margin="10"/>

            <Button Content="Sorts" Style="{StaticResource ButtonStyle}"
                    FontSize="24" FontWeight="Bold"
                    Width="200" Height="50" Margin="10"/>

            <Button Content="Init BDD" Style="{StaticResource ButtonStyle}"
                    FontSize="24" FontWeight="Bold"
                    Width="200" Height="50" Margin="10"/>

            <Button Content="Exit" Style="{StaticResource ButtonStyle}"
                    FontSize="24" FontWeight="Bold"
                    Click="BtnExit"
                    Width="200" Height="50" Margin="10"/>
            
        </StackPanel>
    </Grid>
</Page>
